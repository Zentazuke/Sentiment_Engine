# Copy to /home/kronos/Sentiment_Engine/sentiment.env and edit. All values are optional;
# the engine runs fine with this file empty (lexicon scorer, default DB path).

# --- Scorer (pick at most one). Leave both blank for the fast lexicon. ---
# Lightweight ONNX-int8 (recommended on a small server; see convert_cryptobert_onnx.py):
# SENTIMENT_ONNX_MODEL=/home/kronos/Sentiment_Engine/cryptobert_onnx/model_quantized.onnx
# SENTIMENT_ONNX_TOKENIZER=/home/kronos/Sentiment_Engine/cryptobert_onnx/tokenizer.json
# SENTIMENT_ONNX_LABELS=bearish,neutral,bullish
#
# Or full PyTorch transformer (heavier ~1.5-2 GB; needs `pip install transformers torch`):
# SENTIMENT_TRANSFORMER_MODEL=ElKulako/cryptobert

# --- Storage (optional overrides) ---
# Default DB path is ~/.local/share/sentiment_engine/sentiment_journal.db
# On the server, keep it under the repo dir (local disk, not synced):
# SENTIMENT_JOURNAL_DB=/home/kronos/Sentiment_Engine/data/sentiment_journal.db
# SENTIMENT_MICRO_HISTORY_RETENTION_DAYS=7

# --- Optional source credentials ---
# SENTIMENT_CRYPTOPANIC_TOKEN=
# SENTIMENT_REDDIT_CLIENT_ID=
# SENTIMENT_REDDIT_CLIENT_SECRET=
